{
  "title": "RAG Server Dashboard",
  "uid": "rag-server-001",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "캐시 히트율 (%)",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 80 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "100 * sum(rate(rag_cache_hits_total[5m])) / (sum(rate(rag_cache_hits_total[5m])) + sum(rate(rag_cache_misses_total[5m])))",
          "legendFormat": "히트율"
        }
      ]
    },
    {
      "id": 2,
      "title": "캐시 히트 / 미스 (초당)",
      "type": "timeseries",
      "gridPos": { "x": 6, "y": 0, "w": 9, "h": 6 },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "히트" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "미스" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(rag_cache_hits_total[1m]))",
          "legendFormat": "히트"
        },
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(rag_cache_misses_total[1m]))",
          "legendFormat": "미스"
        }
      ]
    },
    {
      "id": 3,
      "title": "컬렉션별 캐시 히트 (초당)",
      "type": "timeseries",
      "gridPos": { "x": 15, "y": 0, "w": 9, "h": 6 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(rag_cache_hits_total[1m])",
          "legendFormat": "{{collection}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "검색 지연 P50 / P90 / P99 (초)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 7 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.50, sum(rate(rag_search_latency_seconds_bucket[5m])) by (le, search_mode))",
          "legendFormat": "P50 {{search_mode}}"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.90, sum(rate(rag_search_latency_seconds_bucket[5m])) by (le, search_mode))",
          "legendFormat": "P90 {{search_mode}}"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.99, sum(rate(rag_search_latency_seconds_bucket[5m])) by (le, search_mode))",
          "legendFormat": "P99 {{search_mode}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "LLM / 임베딩 호출 (초당)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 7 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(rag_llm_requests_total[1m])",
          "legendFormat": "LLM"
        },
        {
          "datasource": "Prometheus",
          "expr": "rate(rag_embedding_requests_total[1m])",
          "legendFormat": "임베딩"
        }
      ]
    },
    {
      "id": 6,
      "title": "HTTP 요청 수 (초당)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 13, "w": 12, "h": 7 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(http_requests_total[1m])) by (handler)",
          "legendFormat": "{{handler}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "HTTP 에러율 (4xx+5xx / 전체, %)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 13, "w": 12, "h": 7 },
      "fieldConfig": {
        "defaults": { "unit": "percent" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "에러율" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "100 * sum(rate(http_requests_total{status_code=~\"4..|5..\"}[1m])) / sum(rate(http_requests_total[1m]))",
          "legendFormat": "에러율"
        }
      ]
    },
    {
      "id": 8,
      "title": "검색 지연 히트맵 (분포)",
      "type": "heatmap",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 8 },
      "options": {
        "calculate": false,
        "yAxis": { "unit": "s" }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(rag_search_latency_seconds_bucket[1m])) by (le)",
          "format": "heatmap",
          "legendFormat": "{{le}}"
        }
      ]
    }
  ]
}
