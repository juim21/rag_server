# OpenAI API Key
OPENAI_API_KEY=

# Google API Key
GOOGLE_API_KEY=

# Notion API Key
NOTION_API_KEY=

# Main DB
DB_HOST=postgres
DB_PORT=5432
DB_NAME=biz_table
DB_USER=postgres
DB_PASSWORD=postgres

# Vector DB
VECTOR_DB_HOST=postgres
VECTOR_DB_PORT=5432
VECTOR_DB_NAME=biz_rag
VECTOR_DB_USER=postgres
VECTOR_DB_PASSWORD=postgres

# Redis 캐시 (미설정 시 캐시 비활성화)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# API 보안 (미설정 시 인증 비활성화 - 개발 환경)
# 형식: tenant:key 쉼표 구분. tenant가 collection_name 자동 prefix로 사용됨.
# 예) system01:key-aaa,system02:key-bbb
# tenant 없이 key만 작성 시 prefix 미적용 (하위 호환)
API_KEYS=
RATE_LIMIT_PER_MINUTE=100
